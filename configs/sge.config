profiles {
  sge {
    params.queue = params.queue ?: ''
    params.sge_penv = params.sge_penv ?: 'sharedmem'
    params.sge_cluster_options = params.sge_cluster_options ?: ''
    params.conda_base = params.conda_base ?: '/exports/applications/apps/RL9/anaconda/2024.02'

    conda {
      enabled = true
      useMamba = false
      useMicromamba = false
    }

    process {
      executor = 'sge'
      queue = params.queue ?: null
      penv = params.sge_penv
      clusterOptions = params.sge_cluster_options ?: null

      cpus   = { Math.max(1, Math.min(4, params.max_cpus as Integer)) }
      memory = { params.max_memory }
      time   = { params.max_time }

      beforeScript = """
        source ${params.conda_base}/etc/profile.d/conda.sh
      """

      withName: trim_galore {
        cpus   = { Math.max(1, Math.min(params.trim_galore_cpus as Integer, params.max_cpus as Integer)) }
        memory = { params.trim_galore_memory }
      }

      withName: fastqc {
        cpus   = { Math.max(1, Math.min(params.fastqc_cpus as Integer, params.max_cpus as Integer)) }
        memory = { params.fastqc_memory }
      }

      withName: star_index {
        cpus   = { Math.max(1, Math.min(params.star_index_cpus as Integer, params.max_cpus as Integer)) }
        memory = { params.star_index_memory }
      }

      withName: star_align {
        cpus   = { Math.max(1, Math.min(params.star_align_cpus as Integer, params.max_cpus as Integer)) }
        memory = { params.star_align_memory }
      }

      withName: featurecounts {
        cpus   = { Math.max(1, Math.min(params.featurecounts_cpus as Integer, params.max_cpus as Integer)) }
        memory = { params.featurecounts_memory }
      }

      withName: kallisto_quant {
        cpus   = { Math.max(1, Math.min(params.kallisto_quant_cpus as Integer, params.max_cpus as Integer)) }
        memory = { params.kallisto_quant_memory }
      }

      withName: mpileup_gls {
        cpus   = { Math.max(1, Math.min(params.mpileup_gls_cpus as Integer, params.max_cpus as Integer)) }
        memory = { params.mpileup_gls_memory }
      }
    }

    executor {
      $sge {
        queueSize = 100
        submitRateLimit = '20 sec'
        pollInterval = '30 sec'
      }
    }

    report {
      overwrite = true
    }

    timeline {
      overwrite = true
    }
  }
}